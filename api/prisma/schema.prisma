generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id   Int    @id @default(autoincrement())
  nome String @db.VarChar(150)

  cnpj String? @unique

  email String? @unique

  telefone String? @db.VarChar(20)

  endereco String? @db.VarChar(255)

  cep String? @db.VarChar(20)

  numero String? @db.VarChar(20)

  complemento String? @db.VarChar(100)

  bairro String? @db.VarChar(100)

  cidade String? @db.VarChar(100)

  estado String? @db.VarChar(2)

  inscricaoEstadual String? @db.VarChar(30)

  inscricaoMunicipal String? @db.VarChar(30)

  regimeTributario RegimeTributario?

  usuario Usuario?

  clientes Cliente[]

  produtos Produto[]

  propostas Proposta[]

  operacoes Caixa[]

  vendas Venda[]

  agendas Agenda[]

  categorias CategoriaFinanceira[]

  centrosCusto CentroCusto[]

  criadoEm DateTime @default(now())

  atualizadoEm       DateTime            @updatedAt
  configuracaoFiscal ConfiguracaoFiscal?
}

model Usuario {
  id    Int    @id @default(autoincrement())
  nome  String @db.VarChar(100)
  email String @unique
  senha String @db.VarChar(255)

  empresaId Int     @unique
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Cliente {
  id Int @id @default(autoincrement())

  nome String @db.VarChar(150)

  cpf  String?
  cnpj String?

  inscricaoEstadual String? @db.VarChar(30)

  email    String?
  telefone String? @db.VarChar(20)

  endereco    String? @db.VarChar(255)
  cep         String? @db.VarChar(20)
  numero      String? @db.VarChar(20)
  complemento String? @db.VarChar(100)
  bairro      String? @db.VarChar(100)
  cidade      String? @db.VarChar(100)
  estado      String? @db.VarChar(2)

  descricao String? @db.VarChar(255)
  servico   String? @db.VarChar(100)

  pacoteQuinzenal Boolean @default(false)
  pacoteMensal    Boolean @default(false)

  porteCachorro String? @db.VarChar(50)

  empresaId Int

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  propostas Proposta[]
  vendas    Venda[]
  operacoes Caixa[]
  agendas   Agenda[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([empresaId, cpf])
  @@unique([empresaId, cnpj])
  @@unique([empresaId, email])
}

model Produto {
  id Int @id @default(autoincrement())

  nome String @db.VarChar(150)

  descricao String? @db.VarChar(500)

  sku String? @db.VarChar(50)

  codigoBarras String? @db.VarChar(50)

  marca String? @db.VarChar(100)

  categoria String? @db.VarChar(100)

  unidade String @default("UN") @db.VarChar(10)

  ncm String? @db.VarChar(20)

  cest String? @db.VarChar(20)

  cfop String? @db.VarChar(10)

  origem OrigemMercadoria @default(NACIONAL)

  aliquotaIcms Float?

  aliquotaPis Float?

  aliquotaCofins Float?

  aliquotaIpi Float?

  precoVenda Float

  precoCompra Float?

  estoque Int @default(0)

  estoqueMinimo Int @default(0)

  pesoLiquido Float?

  pesoBruto Float?

  largura Float?

  altura Float?

  comprimento Float?

  imagem String? @db.VarChar(255)

  ativo Boolean @default(true)

  empresaId Int

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  vendaItens VendaItem[]

  criadoEm DateTime @default(now())

  atualizadoEm DateTime @updatedAt
}

model Proposta {
  id         Int      @id @default(autoincrement())
  numero     Int
  descricao  String   @db.VarChar(255)
  data       DateTime @default(now())
  status     String   @db.VarChar(100)
  valorTotal Float

  clienteId Int?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Caixa {
  id Int @id @default(autoincrement())

  descricao String? @db.VarChar(255)

  valor     Float
  valorPago Float?

  dataOperacao   DateTime  @default(now())
  dataVencimento DateTime?
  dataPagamento  DateTime?

  status StatusFinanceiro @default(PENDENTE)

  tipoOperacao TipoOperacao

  meioPagamento MeioPagamento?

  categoriaId Int?
  categoria   CategoriaFinanceira? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  centroCustoId Int?
  centroCusto   CentroCusto? @relation(fields: [centroCustoId], references: [id], onDelete: SetNull)

  clienteId Int?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  fornecedor String? @db.VarChar(150)

  recorrente Boolean @default(false)

  tipoRecorrencia TipoRecorrencia @default(NENHUMA)

  parcelas Int @default(1)

  parcelaAtual Int @default(1)

  observacoes String? @db.VarChar(500)

  jurosMaquina Float @default(0)

  comprovanteUrl String? @db.VarChar(255)

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model CategoriaFinanceira {
  id Int @id @default(autoincrement())

  nome String @db.VarChar(100)

  tipo TipoOperacao

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  operacoes Caixa[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model CentroCusto {
  id Int @id @default(autoincrement())

  nome String @db.VarChar(100)

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  operacoes Caixa[]

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

model Venda {
  id Int @id @default(autoincrement())

  data DateTime @default(now())

  total Float

  custoTotal Float @default(0)

  lucro Float @default(0)

  desconto Float @default(0)

  frete Float @default(0)

  seguro Float @default(0)

  outrasDespesas Float @default(0)

  observacoes String? @db.VarChar(500)

  meioPagamento MeioPagamento

  statusNfe StatusNfe @default(PENDENTE)

  numeroNota String? @db.VarChar(50)

  serieNota String? @db.VarChar(10)

  chaveNfe String? @db.VarChar(60)

  protocoloNfe String? @db.VarChar(100)

  xmlNfe String? @db.Text

  pdfDanfe String? @db.VarChar(255)

  dataEmissaoNfe DateTime?

  empresaId Int

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  clienteId Int?

  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  itens VendaItem[]

  criadoEm DateTime @default(now())

  atualizadoEm DateTime @updatedAt
}

model VendaItem {
  id Int @id @default(autoincrement())

  vendaId Int

  venda Venda @relation(fields: [vendaId], references: [id], onDelete: Cascade)

  produtoId Int

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  quantidade Int

  precoUnitario Float

  custoUnitario Float @default(0)

  desconto Float @default(0)

  acrescimo Float @default(0)

  subtotal Float

  ncm String?

  cest String?

  cfop String?

  aliquotaIcms Float?

  aliquotaPis Float?

  aliquotaCofins Float?

  aliquotaIpi Float?

  criadoEm DateTime @default(now())

  atualizadoEm DateTime @updatedAt
}

model Agenda {
  id Int @id @default(autoincrement())

  data DateTime

  horario String @db.VarChar(20)

  servico String? @db.VarChar(100)

  observacao String? @db.VarChar(255)

  status StatusAgenda @default(AGENDADO)

  clienteId Int
  cliente   Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  empresaId Int
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

enum TipoOperacao {
  ENTRADA
  SAIDA
}

enum MeioPagamento {
  PIX
  CARTAO
  DINHEIRO
  BOLETO
  TRANSFERENCIA
}

enum StatusFinanceiro {
  PENDENTE
  PAGO
  ATRASADO
  CANCELADO
}

enum TipoRecorrencia {
  NENHUMA
  SEMANAL
  MENSAL
  ANUAL
}

enum StatusAgenda {
  AGENDADO
  CONCLUIDO
  CANCELADO
}

enum OrigemMercadoria {
  NACIONAL

  ESTRANGEIRA_IMPORTACAO_DIRETA

  ESTRANGEIRA_MERCADO_INTERNO
}

enum RegimeTributario {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum StatusNfe {
  PENDENTE

  AUTORIZADA

  CANCELADA

  REJEITADA
}

model ConfiguracaoFiscal {
  id Int @id @default(autoincrement())

  empresaId Int @unique

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  ambiente AmbienteFiscal @default(HOMOLOGACAO)

  serieNfe Int @default(1)

  serieNfce Int @default(1)

  proximoNumeroNfe Int @default(1)

  proximoNumeroNfce Int @default(1)

  certificadoPfx String? @db.VarChar(255)

  senhaCertificado String? @db.VarChar(255)

  tokenApi String? @db.VarChar(255)

  criadoEm DateTime @default(now())

  atualizadoEm DateTime @updatedAt
}

enum AmbienteFiscal {
  HOMOLOGACAO

  PRODUCAO
}
